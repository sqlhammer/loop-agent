root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
# Keep the format gate practical for an autonomous loop: only real problems fail lint.
dotnet_diagnostic.IDE0005.severity = warning  # unnecessary usings
csharp_using_directive_placement = outside_namespace:silent
csharp_style_namespace_declarations = file_scoped:silent

[*.{json,slnx,csproj,props,targets,yml,yaml}]
indent_size = 2

[*.{ps1,psm1}]
indent_size = 2
